# En Windows, si el servidor no detecta cambios de archivos, descomenta:
# WATCHPACK_POLLING=true

# URL del widget de reservas (Calendly, GoHighLevel, etc.)
NEXT_PUBLIC_CALENDLY_URL=

# Endpoint del formulario de contacto (opcional)
NEXT_PUBLIC_CONTACT_FORM_ENDPOINT=

# Número de WhatsApp para el flujo de compra (formato internacional sin + ni espacios)
# Ejemplo USA: 15551234567 | Ejemplo México: 5215512345678 | Ejemplo Argentina: 5491112345678
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Square Payment Links — una URL por plan (obligatorio para checkout directo)
# Crear en Square Dashboard > Items > Payment Links
NEXT_PUBLIC_SQUARE_LINK_STARTER=
NEXT_PUBLIC_SQUARE_LINK_GROWTH=
NEXT_PUBLIC_SQUARE_LINK_PROFESSIONAL=
NEXT_PUBLIC_SQUARE_LINK_PREMIUM=
NEXT_PUBLIC_SQUARE_LINK_BUSINESS_PLUS=
NEXT_PUBLIC_SQUARE_LINK_BUSINESS_MEETING=
